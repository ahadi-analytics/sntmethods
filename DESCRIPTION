Package: sntmethods
Title: Analytical Methods for Sub-National Tailoring Workflows
Version: 0.0.1
Authors@R: c(
    person("Mohamed A.", "Yusuf",
           role = c("aut", "cre"),
           email = "myusuf@appliedhealthanalytics.org",
           comment = c(ORCID = "0000-0002-9339-4613",
